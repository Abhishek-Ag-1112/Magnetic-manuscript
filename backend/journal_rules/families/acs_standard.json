{
    "family_name": "ACS Standard",
    "citation_style": "apa",
    "abstract_word_limit": 250,
    "section_order": [
        "Abstract",
        "Introduction",
        "Results and Discussion",
        "Conclusion",
        "Methods",
        "Acknowledgments",
        "References"
    ],
    "font": "Times New Roman",
    "font_size": 12,
    "line_spacing": 2.0,
    "margin_top": "1 inch",
    "margin_bottom": "1 inch",
    "margin_left": "1 inch",
    "margin_right": "1 inch",
    "columns": 1,
    "page_limit": 10,
    "keywords_required": false,
    "max_references": 80,
    "page_numbers": true,
    "heading_style": "bold_title_case",
    "abstract_style": "bold_label",
    "reference_style": "numbered_brackets",
    "title_alignment": "center",
    "title_bold": true,
    "title_font_size": 18,
    "author_alignment": "center",
    "section_heading_bold": true,
    "section_heading_size": 12,
    "section_numbered": false,
    "paragraph_indent": 0.3,
    "paragraph_spacing_after": 6,
    "reference_font_size": 10,
    "reference_hanging_indent": 0.3,
    "figure_caption_position": "below",
    "table_caption_position": "above",
    "notes": "ACS journals use Results/Discussion before Methods (Methods at end). Single-column format with author-date or numbered citations depending on specific journal."
}