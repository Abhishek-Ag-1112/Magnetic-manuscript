{
    "family_name": "Nature Style",
    "citation_style": "nature",
    "abstract_word_limit": 200,
    "section_order": [
        "Abstract",
        "Introduction",
        "Results",
        "Discussion",
        "Methods",
        "References"
    ],
    "font": "Times New Roman",
    "font_size": 12,
    "line_spacing": 2.0,
    "margin_top": "1 inch",
    "margin_bottom": "1 inch",
    "margin_left": "1 inch",
    "margin_right": "1 inch",
    "columns": 1,
    "page_limit": 10,
    "methods_at_end": true,
    "no_section_numbers": true,
    "keywords_required": false,
    "max_references": 50,
    "page_numbers": true,
    "heading_style": "bold_title_case",
    "abstract_style": "italic_indented",
    "reference_style": "numbered_superscript",
    "title_alignment": "center",
    "title_bold": true,
    "title_font_size": 16,
    "author_alignment": "center",
    "section_heading_bold": true,
    "section_heading_size": 14,
    "section_numbered": false,
    "paragraph_indent": 0.3,
    "paragraph_spacing_after": 6,
    "reference_font_size": 10,
    "reference_hanging_indent": 0.35,
    "figure_caption_position": "below",
    "table_caption_position": "above",
    "notes": "Nature family journals: Methods section at end. No section numbers. Results before Discussion. Superscript numbered citations."
}