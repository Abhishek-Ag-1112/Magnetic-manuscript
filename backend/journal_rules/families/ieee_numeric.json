{
  "family_name": "IEEE Numeric",
  "citation_style": "ieee",
  "abstract_word_limit": 250,
  "section_order": [
    "Abstract",
    "Introduction",
    "Related Work",
    "Methods",
    "Results",
    "Discussion",
    "Conclusion",
    "Acknowledgments",
    "References"
  ],
  "font": "Times New Roman",
  "font_size": 10,
  "line_spacing": 1.0,
  "margin_top": "0.75 inch",
  "margin_bottom": "0.75 inch",
  "margin_left": "0.625 inch",
  "margin_right": "0.625 inch",
  "columns": 2,
  "page_limit": 8,
  "keywords_required": true,
  "max_references": 40,
  "page_numbers": true,
  "heading_style": "uppercase_roman",
  "abstract_style": "bold_label",
  "reference_style": "numbered_brackets",
  "title_alignment": "center",
  "title_bold": true,
  "title_font_size": 24,
  "author_alignment": "center",
  "section_heading_bold": true,
  "section_heading_size": 10,
  "section_numbered": true,
  "paragraph_indent": 0.2,
  "paragraph_spacing_after": 0,
  "reference_font_size": 8,
  "reference_hanging_indent": 0.25,
  "figure_caption_position": "below",
  "table_caption_position": "above",
  "notes": "IEEE uses two-column format with numbered sections in UPPERCASE ROMAN. Citations use [1] style. Abstract is preceded by bold 'Abstract—' label."
