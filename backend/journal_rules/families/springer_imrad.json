{
    "family_name": "Springer IMRaD",
    "citation_style": "springer",
    "abstract_word_limit": 350,
    "section_order": [
        "Abstract",
        "Introduction",
        "Materials and Methods",
        "Results",
        "Discussion",
        "Conclusion",
        "Acknowledgments",
        "References"
    ],
    "font": "Times New Roman",
    "font_size": 12,
    "line_spacing": 1.5,
    "margin_top": "1 inch",
    "margin_bottom": "1 inch",
    "margin_left": "1 inch",
    "margin_right": "1 inch",
    "columns": 1,
    "page_limit": 25,
    "keywords_required": true,
    "max_references": 60,
    "page_numbers": true,
    "heading_style": "bold_title_case",
    "abstract_style": "bold_label",
    "reference_style": "numbered_brackets",
    "title_alignment": "left",
    "title_bold": true,
    "title_font_size": 16,
    "author_alignment": "left",
    "section_heading_bold": true,
    "section_heading_size": 14,
    "section_numbered": true,
    "paragraph_indent": 0,
    "paragraph_spacing_after": 6,
    "reference_font_size": 10,
    "reference_hanging_indent": 0.35,
    "figure_caption_position": "below",
    "table_caption_position": "above",
    "notes": "Springer IMRaD format. Standard scientific structure. Numbered sections. Keywords required after abstract. Figures/tables numbered sequentially."
}