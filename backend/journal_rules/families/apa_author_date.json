{
    "family_name": "APA Author-Date",
    "citation_style": "apa",
    "abstract_word_limit": 250,
    "section_order": [
        "Abstract",
        "Introduction",
        "Literature Review",
        "Methods",
        "Results",
        "Discussion",
        "Conclusion",
        "References"
    ],
    "font": "Times New Roman",
    "font_size": 12,
    "line_spacing": 2.0,
    "margin_top": "1 inch",
    "margin_bottom": "1 inch",
    "margin_left": "1 inch",
    "margin_right": "1 inch",
    "columns": 1,
    "page_limit": 30,
    "keywords_required": true,
    "max_references": 80,
    "page_numbers": true,
    "heading_style": "bold_title_case",
    "abstract_style": "bold_label",
    "reference_style": "author_date_hanging",
    "title_alignment": "center",
    "title_bold": true,
    "title_font_size": 12,
    "author_alignment": "center",
    "section_heading_bold": true,
    "section_heading_size": 12,
    "section_numbered": false,
    "paragraph_indent": 0.5,
    "paragraph_spacing_after": 0,
    "reference_font_size": 12,
    "reference_hanging_indent": 0.5,
    "running_head": true,
    "figure_caption_position": "below",
    "table_caption_position": "above",
    "notes": "APA 7th edition. Title page with running head. Level 1 headings centered bold, Level 2 left-aligned bold, Level 3 left-aligned bold italic. Double-spaced throughout. Citations use (Author, Year) format."
}